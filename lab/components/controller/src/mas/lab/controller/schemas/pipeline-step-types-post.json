      "id": "execution",
      "label": "Execution",
      "color": "#8b5cf6"
    },
    {
      "id": "extraction",
      "label": "Extraction",
      "color": "#06b6d4"
    },
    {
      "id": "normalization",
      "label": "Normalization",
      "color": "#14b8a6"
    },
    {
      "id": "analysis",
      "label": "Analysis",
      "color": "#f59e0b"
    },
    {
      "id": "evaluation",
      "label": "Evaluation",
      "color": "#ef4444"
    },
    {
      "id": "visualization",
      "label": "Visualization",
      "color": "#22c55e"
    },
    {
      "id": "graph",
      "label": "Graph DB",
      "color": "#a855f7"
    },
    {
      "id": "infrastructure",
      "label": "Infrastructure",
      "color": "#64748b"
    }
  ]
}
