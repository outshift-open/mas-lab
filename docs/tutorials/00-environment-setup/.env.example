# Copy to your project root as .env (gitignored). Never commit API keys.

OPENAI_API_KEY=sk-...

# Optional — required for standard:llm-proxy (corporate / OpenAI-compatible gateway)
# LLM_PROXY_API_BASE=https://llm-proxy.example.com/v1

# Optional — override mas-workspace.yaml infra_refs without editing YAML
# MAS_INFRA_REFS=standard:llm-proxy

# Optional — override agent model (alias: MAS_LLM_MODEL)
# MAS_CTL_MODEL=gpt-4o-mini
