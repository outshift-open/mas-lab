# Copy to docker/.env and adjust paths + secrets.
#
#   cd docker && cp .env.example .env
#
# This file is the canonical source for local Docker secrets (gitignored).
# Shell exports are NOT injected into containers — avoids stale keys from
# other projects or terminals. After edits: task restart (from repo root).

# --- Secrets (required for cloud LLM runs) ---
OPENAI_API_KEY=

# --- Host paths mounted into containers ---
# Workspace: config.yaml, labs/, infra/, project .env
# Default ".." mounts the repository root when you run compose from docker/
MAS_WORKSPACE_MOUNT=..

# Persistent data: trace cache, benchmark outputs, run artifacts
MAS_DATA_MOUNT=./data

# Optional: mount host ~/.mas into the container (user config + legacy paths)
# MAS_USER_CONFIG_MOUNT=~/.mas

# --- Published ports ---
MAS_BACKEND_PORT=8090
MAS_UI_PORT=8080

# API URL injected into the UI (browser on the host reaches this address)
VITE_API_BASE_URL=http://localhost:8090
